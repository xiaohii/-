page {
  min-height: 100%;
  background: linear-gradient(180deg, #f6f3ea 0%, #edf5ee 38%, #f9fbf7 100%);
  color: #223127;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea,
navigator,
image,
swiper,
swiper-item,
picker {
  box-sizing: border-box;
}

button {
  border-radius: 999rpx;
}

.container {
  min-height: 100vh;
  width: 100%;
}

.theme-page {
  min-height: 100vh;
  padding: 40rpx 28rpx 56rpx;
  position: relative;
  overflow: hidden;
}

.theme-card {
  background: rgba(255, 253, 248, 0.96);
  border: 1rpx solid rgba(54, 94, 67, 0.08);
  border-radius: 32rpx;
  box-shadow: 0 24rpx 60rpx rgba(34, 49, 39, 0.08);
}

.theme-heading {
  font-size: 54rpx;
  font-weight: 700;
  line-height: 1.22;
  color: #1f3326;
}

.theme-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #66756a;
}

.theme-tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(47, 111, 82, 0.12);
  color: #2f6f52;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.theme-empty {
  margin-top: 28rpx;
  padding: 44rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #788579;
}
