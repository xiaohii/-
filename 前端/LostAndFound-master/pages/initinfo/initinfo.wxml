<view class="info-page">
  <view class="info-hero">
    <text class="info-tag">Profile Setup</text>
    <text class="info-title">完善你的联系方式</text>
    <text class="info-desc">留下一个常用联系方式，别人才能在找到物品时更快联系到你。</text>
  </view>

  <form bindsubmit="formSubmit" class="info-card">
    <view class="info-block">
      <text class="block-label">联系方式类型</text>
      <picker bindchange="bindPickerChange" value="{{index}}" range="{{array}}">
        <view class="picker-shell">
          <text class="picker-value">{{array[index]}}</text>
          <text class="picker-arrow">选择</text>
        </view>
      </picker>
    </view>

    <view class="info-block">
      <text class="block-label">具体联系方式</text>
      <view class="input-shell">
        <input class="info-input" name="contact_value" placeholder="请输入手机号、QQ 或微信号" />
      </view>
    </view>

    <button class="save-button" formType="submit">保存并进入首页</button>
  </form>
</view>
