.auth-page {
  min-height: 100vh;
  padding: 48rpx 28rpx 56rpx;
  position: relative;
  overflow: hidden;
}

.auth-topbar {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: flex-start;
}

.auth-back {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 248, 0.88);
  border: 1rpx solid rgba(47, 111, 82, 0.12);
  box-shadow: 0 12rpx 28rpx rgba(34, 49, 39, 0.08);
}

.auth-back-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #2f6f52;
}

.auth-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(8rpx);
  opacity: 0.7;
}

.auth-orb-left {
  width: 320rpx;
  height: 320rpx;
  top: -70rpx;
  left: -90rpx;
  background: radial-gradient(circle, rgba(102, 162, 118, 0.35), rgba(102, 162, 118, 0));
}

.auth-orb-right {
  width: 260rpx;
  height: 260rpx;
  top: 180rpx;
  right: -60rpx;
  background: radial-gradient(circle, rgba(241, 196, 90, 0.28), rgba(241, 196, 90, 0));
}

.auth-hero {
  position: relative;
  z-index: 1;
  padding: 22rpx 10rpx 44rpx;
}

.auth-kicker {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(47, 111, 82, 0.12);
  color: #2f6f52;
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.auth-title {
  display: block;
  margin-top: 30rpx;
  font-size: 66rpx;
  font-weight: 700;
  color: #1f3326;
  line-height: 1.14;
}

.auth-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: #647468;
}

.auth-card {
  position: relative;
  z-index: 1;
  padding: 36rpx 30rpx 32rpx;
  border-radius: 34rpx;
  background: rgba(255, 253, 248, 0.96);
  border: 1rpx solid rgba(54, 94, 67, 0.08);
  box-shadow: 0 24rpx 60rpx rgba(34, 49, 39, 0.08);
}

.field-group + .field-group {
  margin-top: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #697668;
}

.field-shell {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #f4f6ef;
  border: 1rpx solid rgba(47, 111, 82, 0.08);
}

.field-icon {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.72;
}

.field-input {
  flex: 1;
  height: 96rpx;
  padding-left: 20rpx;
  font-size: 28rpx;
  color: #223127;
}

.auth-button {
  margin-top: 34rpx;
  height: 92rpx;
  line-height: 92rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2f6f52 0%, #4e9b71 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 18rpx 36rpx rgba(47, 111, 82, 0.22);
}

.auth-tip {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #f8f2dd;
}

.tip-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: #8c6f21;
}

.auth-links {
  margin-top: 28rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
}

.auth-links-text {
  font-size: 24rpx;
  color: #728070;
}

.auth-links-action {
  font-size: 24rpx;
  color: #2f6f52;
  font-weight: 600;
}
