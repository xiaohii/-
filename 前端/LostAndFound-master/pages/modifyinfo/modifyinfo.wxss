.info-page {
  min-height: 100vh;
  padding: 44rpx 28rpx 56rpx;
}

.info-hero {
  padding: 18rpx 10rpx 36rpx;
}

.info-tag {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(47, 111, 82, 0.12);
  color: #2f6f52;
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.info-title {
  display: block;
  margin-top: 28rpx;
  font-size: 58rpx;
  font-weight: 700;
  color: #1f3326;
  line-height: 1.16;
}

.info-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.78;
  color: #657468;
}

.info-card {
  padding: 36rpx 30rpx;
  border-radius: 34rpx;
  background: rgba(255, 253, 248, 0.96);
  border: 1rpx solid rgba(54, 94, 67, 0.08);
  box-shadow: 0 24rpx 60rpx rgba(34, 49, 39, 0.08);
}

.info-block + .info-block {
  margin-top: 28rpx;
}

.block-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #697668;
}

.picker-shell,
.input-shell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 0 26rpx;
  border-radius: 24rpx;
  background: #f4f6ef;
  border: 1rpx solid rgba(47, 111, 82, 0.08);
}

.picker-value {
  font-size: 28rpx;
  color: #223127;
}

.picker-arrow {
  font-size: 24rpx;
  color: #7a867b;
}

.info-input {
  width: 100%;
  height: 96rpx;
  font-size: 28rpx;
  color: #223127;
}

.save-button {
  margin-top: 36rpx;
  height: 92rpx;
  line-height: 92rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2f6f52 0%, #4e9b71 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}
