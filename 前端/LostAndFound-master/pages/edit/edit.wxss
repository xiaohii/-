.editor-page {
  min-height: 100vh;
  padding: 44rpx 28rpx 56rpx;
}

.editor-hero {
  padding: 18rpx 10rpx 34rpx;
}

.editor-tag {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(47, 111, 82, 0.12);
  color: #2f6f52;
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.editor-title {
  display: block;
  margin-top: 28rpx;
  font-size: 58rpx;
  font-weight: 700;
  color: #1f3326;
  line-height: 1.16;
}

.editor-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.78;
  color: #657468;
}

.editor-switch {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.switch-item {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 24rpx;
  background: #f4f6ef;
  color: #697668;
  font-size: 26rpx;
  font-weight: 600;
}

.switch-item-active {
  background: linear-gradient(135deg, #2f6f52 0%, #4e9b71 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(47, 111, 82, 0.22);
}

.editor-card {
  padding: 34rpx 30rpx;
  border-radius: 34rpx;
  background: rgba(255, 253, 248, 0.96);
  border: 1rpx solid rgba(54, 94, 67, 0.08);
  box-shadow: 0 24rpx 60rpx rgba(34, 49, 39, 0.08);
}

.editor-section + .editor-section {
  margin-top: 28rpx;
}

.section-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.section-row-stack {
  display: block;
}

.section-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #697668;
}

.section-caption {
  display: block;
  margin: -2rpx 0 16rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #7a867b;
}

.section-note {
  font-size: 22rpx;
  color: #7a867b;
}

.editor-textarea {
  width: 100%;
  min-height: 280rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #f4f6ef;
  border: 1rpx solid rgba(47, 111, 82, 0.08);
  font-size: 28rpx;
  line-height: 1.8;
  color: #223127;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.preview-image,
.upload-slot {
  width: 31.4%;
  height: 200rpx;
  border-radius: 24rpx;
}

.preview-image {
  background: #eef2ee;
}

.upload-slot {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f4f6ef;
  border: 2rpx dashed rgba(47, 111, 82, 0.18);
}

.upload-icon {
  width: 46rpx;
  height: 46rpx;
  opacity: 0.7;
}

.upload-text {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #7a867b;
}

.picker-shell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 0 26rpx;
  border-radius: 24rpx;
  background: #f4f6ef;
  border: 1rpx solid rgba(47, 111, 82, 0.08);
}

.picker-value {
  font-size: 28rpx;
  color: #223127;
}

.picker-arrow {
  font-size: 24rpx;
  color: #7a867b;
}

.claim-point-input {
  width: 100%;
  height: 92rpx;
  margin-top: 16rpx;
  padding: 0 26rpx;
  border-radius: 24rpx;
  background: #f4f6ef;
  border: 1rpx solid rgba(47, 111, 82, 0.08);
  font-size: 26rpx;
  color: #223127;
  box-sizing: border-box;
}

.submit-button {
  margin-top: 34rpx;
  height: 92rpx;
  line-height: 92rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2f6f52 0%, #76a35a 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}
