.profile-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
}

.profile-hero {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 28rpx 40rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #294b38 0%, #4e8c64 55%, #8fb05e 100%);
  overflow: hidden;
  color: #ffffff;
}

.profile-hero::after {
  content: "";
  position: absolute;
  right: -50rpx;
  top: -50rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.profile-action {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  width: 40rpx;
  height: 40rpx;
  z-index: 1;
}

.profile-badge {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.profile-avatar {
  position: relative;
  z-index: 1;
  display: block;
  width: 156rpx;
  height: 156rpx;
  margin-top: 0;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.18);
  box-shadow: 0 18rpx 34rpx rgba(16, 35, 25, 0.24);
}

.profile-avatar-wrap {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 34rpx;
  padding: 12rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.08));
}

.profile-avatar-wrap::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
}

.profile-avatar-chip {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 248, 0.96);
  box-shadow: 0 10rpx 22rpx rgba(22, 41, 30, 0.14);
  font-size: 20rpx;
  font-weight: 600;
  color: #2f6f52;
  white-space: nowrap;
}

.profile-avatar-tip {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.82);
}

.profile-name {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 24rpx;
  font-size: 46rpx;
  font-weight: 700;
  text-align: center;
}

.profile-contact {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
  max-width: 92%;
  font-size: 26rpx;
  line-height: 1.7;
  text-align: center;
  color: rgba(255, 255, 255, 0.86);
}

.hero-bottom {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14rpx;
  margin-top: 26rpx;
}

.hero-pill {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}

.hero-pill-light {
  background: rgba(255, 255, 255, 0.12);
}

.profile-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 253, 248, 0.96);
  border: 1rpx solid rgba(54, 94, 67, 0.08);
  box-shadow: 0 18rpx 40rpx rgba(34, 49, 39, 0.06);
}

.account-card {
  margin-top: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 18rpx;
  padding: 0 6rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #223127;
}

.section-meta {
  font-size: 22rpx;
  color: #728070;
}

.account-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.account-item {
  min-width: 0;
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  background: #f4f6ef;
}

.account-label {
  display: block;
  font-size: 22rpx;
  color: #778276;
}

.account-value {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
  color: #26382b;
}

.quick-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(54, 94, 67, 0.08);
}

.quick-row:first-of-type {
  padding-top: 0;
  border-top: none;
}

.quick-copy {
  flex: 1;
  min-width: 0;
}

.quick-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #26382b;
}

.quick-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7a867b;
}

.quick-arrow {
  margin-left: 18rpx;
  font-size: 38rpx;
  line-height: 1;
  color: #7c8a7d;
}

.stats-grid {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.guest-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 22rpx;
  padding: 28rpx 26rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, rgba(255, 250, 240, 0.98) 0%, rgba(246, 250, 243, 0.96) 100%);
  border: 1rpx solid rgba(54, 94, 67, 0.08);
  box-shadow: 0 18rpx 40rpx rgba(34, 49, 39, 0.06);
}

.guest-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #223127;
}

.guest-desc {
  font-size: 24rpx;
  line-height: 1.8;
  color: #687669;
}

.guest-login-btn {
  min-width: 220rpx;
  height: 78rpx;
  margin: 6rpx 0 0;
  padding: 0 30rpx;
  line-height: 78rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2f6f52 0%, #4f936c 100%);
  box-shadow: 0 14rpx 28rpx rgba(47, 111, 82, 0.18);
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

.guest-login-btn::after {
  border: none;
}

.stats-card {
  flex: 1;
  padding: 24rpx 18rpx;
  border-radius: 26rpx;
  background: rgba(255, 253, 248, 0.96);
  border: 1rpx solid rgba(54, 94, 67, 0.08);
  box-shadow: 0 18rpx 40rpx rgba(34, 49, 39, 0.06);
  text-align: center;
}

.stats-value {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #2f6f52;
}

.stats-label {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #768376;
}

.tips-card {
  padding-bottom: 10rpx;
}

.tip-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.tip-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #4e9b71;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.8;
  color: #5f6f63;
}

.profile-section {
  margin-top: 24rpx;
}

.profile-empty {
  padding: 42rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 253, 248, 0.96);
  border: 1rpx solid rgba(54, 94, 67, 0.08);
  box-shadow: 0 18rpx 40rpx rgba(34, 49, 39, 0.06);
  font-size: 26rpx;
  line-height: 1.8;
  text-align: center;
  color: #758276;
}

.post-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 253, 248, 0.96);
  border: 1rpx solid rgba(54, 94, 67, 0.08);
  box-shadow: 0 18rpx 40rpx rgba(34, 49, 39, 0.06);
}

.post-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.post-author {
  display: flex;
  align-items: center;
  min-width: 0;
}

.post-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e8eee8;
}

.post-meta {
  min-width: 0;
  margin-left: 18rpx;
}

.post-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #233428;
}

.post-time {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7a867b;
}

.delete-btn {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.7;
}

.post-text {
  display: block;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #324238;
}

.post-chip-row {
  margin-top: 16rpx;
}

.post-meta-chip {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f7eddc;
  font-size: 22rpx;
  color: #98692a;
}

.post-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.post-image {
  width: 31.4%;
  height: 190rpx;
  border-radius: 22rpx;
  background: #eef2ee;
}

.logout-wrap {
  margin-top: 28rpx;
  padding-bottom: 12rpx;
}

.logout-btn {
  height: 92rpx;
  line-height: 92rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #b94840 0%, #d96b5b 100%);
  box-shadow: 0 18rpx 36rpx rgba(171, 71, 62, 0.18);
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.logout-btn::after {
  border: none;
}
