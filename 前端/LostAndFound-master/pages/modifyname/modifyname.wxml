<view class="name-page">
  <view class="name-hero">
    <text class="name-tag">Profile Update</text>
    <text class="name-title">修改名字</text>
    <text class="name-desc">这里可以修改你在校园失物招领里的显示名字，保存后会同步更新到数据库和帖子展示里。</text>
  </view>

  <form bindsubmit="formSubmit" class="name-card">
    <view class="name-block">
      <text class="block-label">当前名字</text>
      <view class="display-shell">
        <text class="display-value">{{currentName || '暂未设置'}}</text>
      </view>
    </view>

    <view class="name-block">
      <text class="block-label">新的名字</text>
      <view class="input-shell">
        <input
          class="name-input"
          bindinput="bindNameInput"
          maxlength="16"
          value="{{nextName}}"
          placeholder="请输入新的名字"
        />
      </view>
      <text class="input-tip">建议使用 2 到 16 个字，方便同学识别你。</text>
    </view>

    <button class="save-button" formType="submit" loading="{{loading}}" disabled="{{loading}}">
      {{loading ? '保存中...' : '保存新名字'}}
    </button>
  </form>
</view>
