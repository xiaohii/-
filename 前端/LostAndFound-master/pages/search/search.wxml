<view class="search-page">
  <view class="search-hero">
    <text class="search-tag">Quick Search</text>
    <text class="search-title">搜索失物线索</text>
    <text class="search-desc">输入物品名称、地点或描述关键词，快速筛出对应的寻物与招领信息。</text>
  </view>

  <view class="search-bar-card">
    <view class="search-input-shell">
      <icon type="search" size="16"></icon>
      <input class="search-input" type="text" placeholder="例如：校园卡、黑色雨伞、第二食堂" value="{{inputVal}}" bindinput="bindKeyInput" bindconfirm="addItem" confirm-type="search" />
      <text wx:if="{{inputVal}}" class="search-clear" bindtap="clearInput">清空</text>
    </view>
    <button class="search-button" bindtap="addItem">搜索</button>
  </view>

  <view wx:if="{{searchs.length}}" class="history-card">
    <view class="section-head">
      <text class="section-title">最近搜索</text>
      <text class="section-action" bindtap="clearHistory">清空</text>
    </view>

    <view class="history-list">
      <block wx:for="{{searchs}}" wx:key="key">
        <view class="history-chip" bindtap="reuseKeyword" data-key="{{item.text}}">
          <text class="history-chip-text">{{item.text}}</text>
          <text class="history-chip-remove" catchtap="deleteItem" data-key="{{item.key}}">×</text>
        </view>
      </block>
    </view>
  </view>

  <view class="result-card">
    <view class="section-head">
      <text class="section-title">搜索结果</text>
      <text class="section-meta">{{listofitem.length}} 条</text>
    </view>

    <view wx:if="{{!listofitem.length}}" class="empty-card">输入关键词开始搜索，也可以先点历史记录快速回搜。</view>

    <block wx:for="{{listofitem}}" wx:key="itemKey">
      <view class="feed-card">
        <view class="feed-card-head">
          <navigator url="../userinfo/userinfo?userid={{item.userid}}" class="author-box">
            <image src="{{item.usericon}}" class="author-avatar"></image>
            <view class="author-meta">
              <text class="author-name">{{item.username}}</text>
              <text class="author-time">{{item.sub_time}}</text>
            </view>
          </navigator>
        </view>

        <text class="feed-card-text">{{item.text}}</text>

        <view wx:if="{{item.claimPoint}}" class="claim-row">
          <text class="claim-chip">认领点：{{item.claimPoint}}</text>
        </view>

        <view wx:if="{{item.image != ''}}" class="image-grid">
          <block wx:for="{{item.imagelist}}" wx:for-item="specific_url" wx:key="*this">
            <image bindtap="photopreview" data-list="{{item.imagelist}}" src="{{specific_url}}" data-src="{{specific_url}}" class="feed-image" mode="aspectFill"></image>
          </block>
        </view>
      </view>
    </block>
  </view>
</view>
