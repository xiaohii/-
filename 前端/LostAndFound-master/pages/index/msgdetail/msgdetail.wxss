.detail-page {
  min-height: 100vh;
  padding: 34rpx 24rpx 56rpx;
  background:
    radial-gradient(circle at top right, rgba(247, 229, 191, 0.38), transparent 34%),
    linear-gradient(180deg, #f7f0e2 0%, #f3f6ee 42%, #edf3ef 100%);
}

.detail-card,
.comment-card {
  padding: 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 253, 248, 0.96);
  border: 1rpx solid rgba(54, 94, 67, 0.08);
  box-shadow: 0 20rpx 48rpx rgba(34, 49, 39, 0.08);
}

.comment-card {
  margin-top: 24rpx;
}

.detail-author {
  display: flex;
  align-items: center;
}

.detail-avatar,
.comment-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: #e8eee8;
}

.detail-meta {
  margin-left: 18rpx;
}

.detail-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #233428;
}

.detail-time {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7a867b;
}

.detail-text {
  display: block;
  margin-top: 24rpx;
  font-size: 30rpx;
  line-height: 1.9;
  color: #324238;
}

.detail-claim {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #f7eddc;
}

.detail-claim-label {
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.65);
  font-size: 22rpx;
  color: #98692a;
}

.detail-claim-value {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.7;
  color: #7e5b26;
}

.detail-engagement {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.detail-engagement-chip,
.comment-count {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef4ed;
  font-size: 22rpx;
  color: #2f6f52;
}

.detail-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 26rpx;
}

.detail-actions {
  margin-top: 22rpx;
}

.detail-like-button {
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 86rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #eef4ed 0%, #e7efe6 100%);
  color: #2f6f52;
  font-size: 28rpx;
  font-weight: 600;
}

.detail-like-button::after {
  border: none;
}

.detail-like-button-active {
  background: linear-gradient(135deg, #e16c63 0%, #d24f4c 100%);
  color: #fffaf5;
  box-shadow: 0 14rpx 30rpx rgba(210, 79, 76, 0.22);
}

.detail-like-icon {
  font-size: 32rpx;
  line-height: 1;
}

.detail-like-text {
  font-size: 26rpx;
}

.detail-action-tip {
  display: block;
  margin-top: 12rpx;
  text-align: center;
  font-size: 22rpx;
  color: #849084;
}

.detail-image {
  width: 31.4%;
  height: 210rpx;
  border-radius: 24rpx;
  background: #eef2ee;
}

.comment-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.comment-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #233428;
}

.comment-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7c887d;
}

.composer {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fffdf8 0%, #f7f3ea 100%);
  border: 1rpx solid rgba(82, 110, 89, 0.08);
}

.composer-input {
  width: 100%;
  min-height: 164rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #2c3d33;
}

.composer-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.composer-length {
  font-size: 22rpx;
  color: #8d998f;
}

.composer-button {
  margin: 0;
  padding: 0 32rpx;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #335f49 0%, #4f7d63 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.composer-button::after {
  border: none;
}

.comment-state {
  margin-top: 24rpx;
  padding: 26rpx 22rpx;
  border-radius: 24rpx;
  background: #f7f8f3;
  font-size: 25rpx;
  text-align: center;
  color: #7c887d;
}

.comment-item {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(83, 102, 88, 0.08);
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.comment-name {
  flex: 1;
  font-size: 27rpx;
  font-weight: 600;
  color: #2c3f34;
}

.comment-time {
  font-size: 22rpx;
  color: #8b968d;
}

.comment-content {
  display: block;
  margin-top: 10rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: #425146;
  word-break: break-all;
}
